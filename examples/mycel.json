{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "description": "mycel discord bot configuration",
  "type": "object",
  "x-nixcfg-name": "mycel",
  "properties": {
    "data_dir": {
      "type": "string",
      "description": "directory for the database, models, and workspace",
      "default": "/var/lib/mycel"
    },
    "model": {
      "type": "string",
      "description": "anthropic model to use",
      "default": "claude-sonnet-4-20250514"
    },
    "log_level": {
      "$ref": "#/$defs/LogLevel",
      "description": "log level",
      "default": "info"
    },
    "cache_warming": {
      "type": "boolean",
      "description": "keep the prompt cache warm between messages",
      "default": false
    },
    "discord_token": {
      "type": "string",
      "description": "discord bot token",
      "x-nixcfg-secret": true
    },
    "anthropic_key": {
      "type": ["string", "null"],
      "description": "anthropic API key (not needed with OAuth)",
      "x-nixcfg-secret": true
    }
  },
  "required": ["data_dir", "model", "log_level", "discord_token"],
  "$defs": {
    "LogLevel": {
      "type": "string",
      "enum": ["trace", "debug", "info", "warn", "error"]
    }
  }
}
