{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ComplexConfig",
  "description": "complex example exercising all schema features",
  "type": "object",
  "x-nixcfg-name": "complex-app",
  "properties": {
    "hostname": {
      "type": "string",
      "description": "server hostname",
      "default": "localhost"
    },
    "port": {
      "type": "integer",
      "format": "uint16",
      "minimum": 0,
      "maximum": 65535,
      "description": "listen port",
      "default": 8080,
      "x-nixcfg-port": true
    },
    "debug": {
      "type": "boolean",
      "description": "enable debug mode",
      "default": false
    },
    "workers": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0,
      "description": "number of worker threads",
      "default": 4
    },
    "max_retries": {
      "type": "integer",
      "format": "int32",
      "description": "max retries (-1 for unlimited)",
      "default": -1
    },
    "data_dir": {
      "type": "string",
      "description": "data directory",
      "default": "/var/lib/complex"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "metadata tags",
      "default": []
    },
    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "key-value labels"
    },
    "log_level": {
      "$ref": "#/$defs/LogLevel",
      "description": "log level",
      "default": "info"
    },
    "optional_feature": {
      "type": ["string", "null"],
      "description": "optional feature flag"
    },
    "database": {
      "$ref": "#/$defs/DatabaseConfig",
      "description": "database connection settings"
    },
    "api_key": {
      "type": "string",
      "description": "api authentication key",
      "x-nixcfg-secret": true
    },
    "db_password": {
      "type": ["string", "null"],
      "description": "database password",
      "x-nixcfg-secret": true
    },
    "allowed_origins": {
      "type": ["array", "null"],
      "items": { "type": "string" },
      "description": "CORS allowed origins"
    },
    "load_threshold": {
      "type": "number",
      "description": "cosine similarity threshold (0.0-1.0)",
      "default": 0.5
    }
  },
  "required": ["hostname", "port", "debug", "workers", "max_retries", "data_dir", "tags", "log_level", "api_key", "database", "load_threshold"],
  "$defs": {
    "LogLevel": {
      "type": "string",
      "enum": ["trace", "debug", "info", "warn", "error"]
    },
    "DatabaseConfig": {
      "type": "object",
      "description": "database connection settings",
      "properties": {
        "host": {
          "type": "string",
          "description": "database host",
          "default": "localhost"
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0,
          "maximum": 65535,
          "description": "database port",
          "default": 5432,
          "x-nixcfg-port": true
        },
        "name": {
          "type": "string",
          "description": "database name",
          "default": "mydb"
        },
        "pool_size": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0,
          "description": "connection pool size",
          "default": 10
        }
      },
      "required": ["host", "port", "name", "pool_size"]
    }
  }
}
